# Build artifacts
target/
# Note: Cargo.lock is NOT ignored - it's committed for reproducible builds

# Version control
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Note: tests/ and benches/ are intentionally NOT ignored. Cargo.toml declares
# explicit [[test]] and [[bench]] targets, so cargo fails to parse the manifest
# if those source files are absent - even when only building the binary. They are
# only used in the builder stage and never reach the final multi-stage image.

# Documentation (can be added to image if needed)
*.md

# Temporary files
.tmp
tmp/
temp/

# Archives
*.tar.gz
*.zip

# Python
*.pyc
__pycache__/
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log
yarn-error.log

# Environment files
.env
.env.local
.env.*.local

# Dashboard build
dashboard/dist/
dashboard/build/

# Logs
*.log
logs/
